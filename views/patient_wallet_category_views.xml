<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_wallet_category_tree" model="ir.ui.view">
        <field name="name">patient.wallet.category.tree</field>
        <field name="model">patient.wallet.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="category_type"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_patient_wallet_category_form" model="ir.ui.view">
        <field name="name">patient.wallet.category.form</field>
        <field name="model">patient.wallet.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code" placeholder="Autogenerado si lo dejas vacío"/>
                        <field name="category_type"/>
                        <field name="company_id"/>
                        <field name="active"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient_wallet_category" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">patient.wallet.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
