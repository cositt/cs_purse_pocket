<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_wallet_family_link_tree" model="ir.ui.view">
        <field name="name">patient.wallet.family.link.tree</field>
        <field name="model">patient.wallet.family.link</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient_id"/>
                <field name="payer_id"/>
                <field name="relationship"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_patient_wallet_family_link_form" model="ir.ui.view">
        <field name="name">patient.wallet.family.link.form</field>
        <field name="model">patient.wallet.family.link</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="patient_id"/>
                        <field name="payer_id"/>
                        <field name="relationship"/>
                        <field name="company_id"/>
                        <field name="active"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient_wallet_family_link" model="ir.actions.act_window">
        <field name="name">Vínculos familiares</field>
        <field name="res_model">patient.wallet.family.link</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
