<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_wallet_move_tree" model="ir.ui.view">
        <field name="name">patient.wallet.move.tree</field>
        <field name="model">patient.wallet.move</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="account_id"/>
                <field name="move_type"/>
                <field name="direction"/>
                <field name="amount"/>
                <field name="signed_amount"/>
                <field name="origin_model"/>
                <field name="origin_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_patient_wallet_move_form" model="ir.ui.view">
        <field name="name">patient.wallet.move.form</field>
        <field name="model">patient.wallet.move</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="account_id"/>
                        <field name="date"/>
                        <field name="datetime"/>
                        <field name="move_type"/>
                        <field name="direction"/>
                        <field name="amount"/>
                        <field name="signed_amount" readonly="1"/>
                        <field name="description"/>
                        <field name="category_id"/>
                        <field name="origin_model"/>
                        <field name="origin_id"/>
                        <field name="responsible_id"/>
                        <field name="state"/>
                        <field name="hash" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient_wallet_move" model="ir.actions.act_window">
        <field name="name">Movimientos de monedero</field>
        <field name="res_model">patient.wallet.move</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
