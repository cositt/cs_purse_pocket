<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_wallet_account_tree" model="ir.ui.view">
        <field name="name">patient.wallet.account.tree</field>
        <field name="model">patient.wallet.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="company_id"/>
                <field name="balance"/>
                <field name="total_recargas"/>
                <field name="total_consumos"/>
                <field name="allow_negative"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_patient_wallet_account_form" model="ir.ui.view">
        <field name="name">patient.wallet.account.form</field>
        <field name="model">patient.wallet.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="patient_id"/>
                        <field name="company_id"/>
                        <field name="center_id"/>
                        <field name="responsible_id"/>
                        <field name="balance" readonly="1"/>
                        <field name="total_recargas" readonly="1"/>
                        <field name="total_consumos" readonly="1"/>
                        <field name="allow_negative"/>
                        <field name="negative_limit"/>
                        <field name="state"/>
                        <field name="notes"/>
                    </group>
                    <notebook>
                        <page string="Movimientos">
                            <field name="move_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="move_type"/>
                                    <field name="direction"/>
                                    <field name="amount"/>
                                    <field name="signed_amount"/>
                                    <field name="description"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient_wallet_account" model="ir.actions.act_window">
        <field name="name">Monederos</field>
        <field name="res_model">patient.wallet.account</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
