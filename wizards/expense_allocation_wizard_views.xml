<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_expense_allocation_wizard_form" model="ir.ui.view">
        <field name="name">expense.allocation.wizard.form</field>
        <field name="model">patient.wallet.expense.allocation.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear imputacion de gasto">
                <group>
                    <field name="description"/>
                    <field name="date"/>
                    <field name="category_id"/>
                    <field name="total_amount"/>
                </group>
                <footer>
                    <button name="action_open_allocation" string="Continuar" type="object" class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_expense_allocation_wizard" model="ir.actions.act_window">
        <field name="name">Nuevo reparto de gasto</field>
        <field name="res_model">patient.wallet.expense.allocation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
